{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile & Run C++ (C++20)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++20",          // Enable C++20
                "-Wall",               // Show all warnings
                "-Wextra",             // Show extra warnings
                "-Wshadow",            // Warn about variable shadowing
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compiles and runs C++ files with C++20 standard"
        }
    ]
}
