{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build and run current file with C++23",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-Command",
        "g++ -std=c++23 -Wall -Wextra \"${file}\" -o main.exe; .\\main.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
